{
	"name": "sado",
	"version": "0.7.0",
	"description": "CLI toolkit combining cac (command parsing) + ora (spinners) + picocolors (colors) + @clack/prompts (input) + log-symbols + boxen",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"default": "./dist/index.mjs"
		}
	},
	"types": "./dist/index.d.mts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write",
		"format": "biome format --write",
		"test": "bun test",
		"test:watch": "bun test --watch"
	},
	"dependencies": {
		"@clack/prompts": "^1.5.0",
		"boxen": "^8.0.1",
		"cac": "^7.0.0",
		"log-symbols": "^7.0.1",
		"ora": "^9.4.0",
		"picocolors": "^1.1.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@types/bun": "latest",
		"tsdown": "^0.22.1"
	},
	"license": "MIT",
	"author": "zfadhli",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/zfadhli/sado.git"
	},
	"bugs": {
		"url": "https://github.com/zfadhli/sado/issues"
	},
	"homepage": "https://github.com/zfadhli/sado#readme",
	"keywords": [
		"cli",
		"cac",
		"ora",
		"spinner",
		"picocolors",
		"colors",
		"log-symbols",
		"boxen",
		"clack",
		"prompts",
		"terminal",
		"command-line"
	],
	"engines": {
		"node": ">=18"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
